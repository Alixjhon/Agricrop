# Backend Environment Variables
# Copy this file to .env and update with your values

# Server Configuration
PORT=5001
NODE_ENV=production

# Database Configuration
# PostgreSQL connection string (required for production)
# Format: postgresql://username:password@host:port/database?sslmode=require
DATABASE_URL=postgresql://username:password@localhost:5432/cropwise_db

# JWT Secret - Generate a strong random string for production
# You can generate one using: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=your_super_secret_jwt_key_here

# AI API Keys
# Groq API Key - Get from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Google Gemini API Key - Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: OpenAI API Key (alternative to Groq/Gemini)
# OPENAI_API_KEY=your_openai_api_key_here

# Image Service
# Unsplash API Key - Get from https://unsplash.com/developers
UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Frontend URL - Used for CORS configuration
# For local development: http://localhost:5173
# For Render production: https://cropwise-frontend.onrender.com
FRONTEND_URL=http://localhost:5173

# Optional: File Upload Configuration
# MAX_FILE_SIZE=10485760  # 10MB in bytes
